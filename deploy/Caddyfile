# Reverse proxy for Blocks (MycoDAO Next.js) — used by `docker compose --profile tls up -d`
# DNS: blocks.mycodao.com → this VM’s public IP (or Cloudflare orange-cloud with origin on 443).

blocks.mycodao.com {
    encode gzip zstd
    reverse_proxy mycodao:3004
}

# Legacy hostname — redirect to canonical blocks host.
pulse.mycodao.com {
    redir https://blocks.mycodao.com{uri} permanent
}
